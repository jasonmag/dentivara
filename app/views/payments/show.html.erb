<% content_for :title, "Payment" %>

<div class="app-card">
  <%= render @payment %>

  <div class="mt-6 flex flex-wrap gap-2">
    <%= link_to "Edit this payment", edit_payment_path(@payment), class: "btn btn-primary" %>
    <%= link_to "Back to payments", payments_path, class: "btn btn-secondary" %>
    <%= button_to "Destroy this payment", @payment, method: :delete, class: "btn btn-danger" %>
  </div>
</div>

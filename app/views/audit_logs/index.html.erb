<% content_for :title, "Audit Logs" %>
<div class="space-y-6">
  <div class="page-header">
    <h1 class="page-title">Audit Logs</h1>
    <%= link_to "Export CSV", audit_logs_path(format: :csv), class: "btn btn-secondary" %>
  </div>

  <section class="table-shell">
    <table class="data-table">
      <thead>
        <tr>
          <th>Timestamp</th>
          <th>User</th>
          <th>Action</th>
          <th>Resource</th>
          <th>Hash</th>
        </tr>
      </thead>
      <tbody>
        <% @audit_logs.each do |log| %>
          <tr>
            <td><%= l(log.created_at, format: :long) %></td>
            <td><%= log.user&.email || "System" %></td>
            <td><%= log.action %></td>
            <td><%= "#{log.auditable_type}##{log.auditable_id}" %></td>
            <td class="font-mono text-xs"><%= log.event_hash.to_s.first(20) %>...</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </section>
</div>

<% content_for :title, "Invoices" %>

<div class="space-y-8">
  <section class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
    <div>
      <h1 class="page-title">Financial Overview</h1>
      <p class="serene-subheading mt-1">Managing revenue, outstanding balances, and billing flow.</p>
    </div>
    <div class="flex gap-3">
      <%= link_to payments_path, class: "btn btn-secondary gap-2" do %>
        <span class="material-symbols-outlined text-base">payments</span>
        <span>View Payments</span>
      <% end %>
      <%= link_to new_invoice_path, class: "btn btn-primary gap-2" do %>
        <span class="material-symbols-outlined text-base">receipt_long</span>
        <span>Create Invoice</span>
      <% end %>
    </div>
  </section>

  <section class="grid grid-cols-1 gap-6 md:grid-cols-3">
    <article class="serene-kpi">
      <p class="text-xs font-semibold uppercase tracking-wider text-stone-500">Revenue (This Month)</p>
      <p class="mt-2 font-serif text-4xl text-stone-800"><%= number_to_currency(@monthly_revenue) %></p>
    </article>
    <article class="serene-kpi">
      <p class="text-xs font-semibold uppercase tracking-wider text-stone-500">Outstanding Balance</p>
      <p class="mt-2 font-serif text-4xl text-stone-800"><%= number_to_currency(@outstanding_balance) %></p>
    </article>
    <article class="serene-kpi">
      <p class="text-xs font-semibold uppercase tracking-wider text-stone-500">Claim Success Rate</p>
      <p class="mt-2 font-serif text-4xl text-stone-800"><%= @claim_success_rate %>%</p>
    </article>
  </section>

  <section class="table-shell">
    <table class="data-table">
      <thead>
        <tr>
          <th>Invoice</th>
          <th>Patient</th>
          <th>Status</th>
          <th>Total</th>
          <th>Balance</th>
          <th>Issued</th>
          <th class="text-right">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @invoices.each do |invoice| %>
          <% status_class = case invoice.status
                           when 'paid' then 'bg-[#E8F1E9] text-[#4a654e]'
                           when 'partially_paid' then 'bg-amber-50 text-amber-700'
                           when 'cancelled', 'refunded' then 'bg-red-50 text-red-700'
                           else 'bg-stone-100 text-stone-700'
                           end %>
          <tr>
            <td class="font-semibold text-stone-800">#<%= invoice.id %></td>
            <td><%= invoice.patient.full_name %></td>
            <td><span class="rounded-full px-3 py-1 text-xs font-semibold <%= status_class %>"><%= invoice.status.humanize %></span></td>
            <td><%= number_to_currency(invoice.total_amount) %></td>
            <td><%= number_to_currency(invoice.balance_amount) %></td>
            <td><%= invoice.issued_on.present? ? l(invoice.issued_on, format: :long) : 'N/A' %></td>
            <td class="text-right"><%= link_to "View", invoice_path(invoice), class: "btn btn-secondary px-3 py-1.5 text-xs" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </section>
</div>

<% content_for :title, "Document Template" %>
<div class="space-y-4" data-controller="modal">
  <div class="app-card kv-grid">
    <div class="kv-item"><p class="kv-label">Name</p><p class="kv-value"><%= @document_template.name %></p></div>
    <div class="kv-item"><p class="kv-label">Kind</p><p class="kv-value"><%= @document_template.kind.humanize %></p></div>
    <% unless @document_template.kind == "prescription" %>
      <div class="kv-item"><p class="kv-label">Signature Name</p><p class="kv-value"><%= @document_template.digital_signature_name.presence || "N/A" %></p></div>
      <div class="kv-item"><p class="kv-label">Signature Title</p><p class="kv-value"><%= @document_template.digital_signature_title.presence || "N/A" %></p></div>
    <% end %>
    <div class="kv-item sm:col-span-2"><p class="kv-label">Header</p><p class="kv-value whitespace-pre-line"><%= @document_template.header_text %></p></div>
    <div class="kv-item sm:col-span-2"><p class="kv-label">Information Header</p><p class="kv-value whitespace-pre-line"><%= @document_template.information_header_text.presence || "N/A" %></p></div>
    <div class="kv-item sm:col-span-2"><p class="kv-label">Body Template</p><p class="kv-value whitespace-pre-line"><%= @document_template.body_template %></p></div>
    <div class="kv-item sm:col-span-2"><p class="kv-label">Footer</p><p class="kv-value whitespace-pre-line"><%= @document_template.footer_text %></p></div>
  </div>
  <div class="flex flex-wrap gap-2">
    <button type="button" class="btn btn-secondary" data-action="modal#open">Preview</button>
    <%= link_to "Edit", edit_document_template_path(@document_template), class: "btn btn-primary" %>
    <%= link_to "Back", document_templates_path, class: "btn btn-secondary" %>
    <% unless @document_template.deleted? %>
      <%= button_to "Delete Template", @document_template, method: :delete, class: "btn btn-danger", data: { turbo_confirm: "Delete this template? Existing prescriptions will keep using it, but it will be hidden from the app." } %>
    <% end %>
  </div>

  <dialog
    data-modal-target="dialog"
    data-action="click->modal#closeOnBackdrop"
    class="m-auto w-[92vw] max-w-3xl rounded-2xl border border-stone-200 p-0 backdrop:bg-black/50"
  >
    <div class="flex items-center justify-between border-b border-stone-200 px-4 py-3">
      <h3 class="font-semibold text-stone-800">Template Preview: <%= @document_template.name %></h3>
      <div class="flex items-center gap-2">
        <button type="button" class="btn btn-secondary px-3 py-1.5 text-xs" data-action="modal#print">Print</button>
        <button type="button" class="btn btn-secondary px-3 py-1.5 text-xs" data-action="modal#close">Close</button>
      </div>
    </div>
    <div class="bg-stone-50 p-4">
      <% if @document_template.kind == "prescription" %>
        <div data-modal-target="printArea">
          <%= render "shared/prescription_sheet", template: @document_template, rendered: @rendered_preview %>
        </div>
      <% else %>
        <article data-modal-target="printArea" class="rx-sheet rounded-xl border border-stone-300 bg-white shadow-sm">
          <header class="rx-header border-b-2 border-stone-900 px-5 py-4">
            <% if @document_template.logo.attached? %>
              <%= image_tag @document_template.logo, class: "mb-2 h-16 rounded bg-white object-contain" %>
            <% else %>
              <h1 class="rx-title text-3xl tracking-widest text-stone-900">Rx</h1>
            <% end %>
            <p class="rx-subtitle mt-1 text-xs uppercase tracking-[0.16em] text-stone-600">Document Template Preview</p>
          </header>

          <section class="rx-body min-h-[320px] px-5 py-4">
            <header class="whitespace-pre-line text-sm text-stone-700"><%= @rendered_preview[:header] %></header>
            <section class="mt-3 whitespace-pre-line rounded-lg border border-stone-200 bg-stone-50 p-3 text-sm text-stone-700"><%= @rendered_preview[:information_header] %></section>
            <main class="mt-4">
              <pre class="rx-content whitespace-pre-wrap text-[15px] leading-relaxed text-stone-800"><%= @rendered_preview[:body] %></pre>
            </main>
            <footer class="mt-4 whitespace-pre-line text-sm text-stone-700"><%= @rendered_preview[:footer] %></footer>
          </section>
        </article>
      <% end %>
      <p class="mt-3 text-xs text-stone-500">Using realistic sample data for preview only.</p>
    </div>
  </dialog>
</div>

<% content_for :title, "Prescription" %>

<div class="space-y-6" data-controller="prescription-preview">
  <section class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
    <div>
      <h1 class="page-title">Prescription for <%= @patient.full_name %></h1>
      <p class="serene-subheading mt-1">Status: <span class="font-semibold text-stone-700"><%= @prescription.status.humanize %></span></p>
    </div>
    <div class="flex flex-wrap gap-2">
      <%= link_to "Back", patient_prescriptions_path(@patient), class: "btn btn-secondary" %>
      <button type="button" class="btn btn-secondary" data-action="prescription-preview#open">Preview</button>
      <% if @prescription.can_finalize? %>
        <%= button_to "Finalize", finalize_patient_prescription_path(@patient, @prescription), method: :patch, class: "btn btn-primary" %>
      <% end %>
    </div>
  </section>

  <section class="app-card space-y-4">
    <div class="kv-grid">
      <div class="kv-item"><p class="kv-label">Issued On</p><p class="kv-value"><%= l(@prescription.issued_on, format: :long) %></p></div>
      <div class="kv-item"><p class="kv-label">Drafted By</p><p class="kv-value"><%= @prescription.drafted_by_user.name %></p></div>
      <div class="kv-item"><p class="kv-label">Signed By</p><p class="kv-value"><%= @prescription.signed_by_user&.name || "N/A" %></p></div>
      <div class="kv-item"><p class="kv-label">Signed At</p><p class="kv-value"><%= @prescription.signed_at.present? ? l(@prescription.signed_at, format: :long) : "N/A" %></p></div>
    </div>

    <div>
      <p class="kv-label mb-2">Prescription Body</p>
      <pre class="whitespace-pre-wrap rounded-lg border border-stone-200 bg-stone-50 p-4 text-sm text-stone-800"><%= @prescription.body %></pre>
    </div>

    <% if @prescription.signature_snapshot.present? %>
      <div>
        <p class="kv-label mb-1">Digital Signature Record</p>
        <p class="text-sm text-stone-700"><%= @prescription.signature_snapshot %></p>
        <% if @prescription.signature_image.attached? %>
          <div class="mt-3">
            <p class="kv-label mb-1">Signature</p>
            <%= image_tag @prescription.signature_image, class: "h-24 rounded border border-stone-200 bg-white p-2 object-contain" %>
          </div>
        <% end %>
      </div>
    <% end %>
  </section>

  <% if @prescription.can_sign? && (current_user&.dentist? || current_user&.clinic_owner? || current_user&.system_admin?) %>
    <section class="app-card" data-controller="signature-pad">
      <h3 class="mb-2 font-serif text-xl text-stone-800">Dentist Signature</h3>
      <p class="mb-3 text-sm text-stone-600">Sign using mouse, touchpad, iPad, or phone.</p>
      <div class="w-full max-w-[700px]">
        <div class="relative overflow-hidden rounded-lg border border-stone-300 bg-white">
          <p data-signature-pad-target="placeholder" class="absolute left-3 top-3 text-xs text-stone-400">Sign here</p>
          <canvas data-signature-pad-target="canvas" class="block touch-none"></canvas>
        </div>

        <%= form_with url: sign_patient_prescription_path(@patient, @prescription), method: :patch, class: "mt-4 flex flex-wrap items-center gap-2" do %>
          <%= hidden_field_tag :signature_data, "", data: { signature_pad_target: "hidden" } %>
          <label class="inline-flex items-center gap-2 text-sm text-stone-700">
            <%= check_box_tag :signature_confirmed, "1", false, required: true, class: "m-0 h-4 w-4 shrink-0" %>
            <span class="leading-tight">I confirm that this is my authentic dentist signature for this prescription.</span>
          </label>
          <button type="button" class="btn btn-secondary" data-action="signature-pad#clear">Clear</button>
          <%= submit_tag "Sign Prescription", class: "btn btn-primary" %>
        <% end %>
      </div>
    </section>
  <% end %>

  <dialog
    data-prescription-preview-target="dialog"
    data-action="click->prescription-preview#closeOnBackdrop"
    class="m-auto w-[92vw] max-w-3xl rounded-2xl border border-stone-200 p-0 backdrop:bg-black/50"
  >
    <div class="flex items-center justify-between border-b border-stone-200 px-4 py-3">
      <h3 class="font-semibold text-stone-800">Prescription Preview</h3>
      <div class="flex items-center gap-2">
        <button type="button" class="btn btn-secondary px-3 py-1.5 text-xs" data-action="prescription-preview#print">Print</button>
        <button type="button" class="btn btn-secondary px-3 py-1.5 text-xs" data-action="prescription-preview#close">Close</button>
      </div>
    </div>
    <div class="bg-stone-50 p-4">
      <div data-prescription-preview-target="printArea">
        <%= render "shared/prescription_sheet",
          template: @prescription.document_template,
          rendered: @rendered_prescription,
          signature_image: @prescription.signature_image,
          signature_name: @prescription.signed_by_user&.name || @prescription.drafted_by_user.name,
          signature_title: "Licensed Dentist" %>

      </div>
    </div>
  </dialog>
</div>

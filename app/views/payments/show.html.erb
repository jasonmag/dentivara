<% content_for :title, "Payment" %>

<div class="space-y-4">
  <div class="app-card">
    <%= render @payment %>
  </div>

  <div class="flex flex-wrap gap-2">
    <%= link_to "Edit", edit_payment_path(@payment), class: "btn btn-primary" %>
    <%= link_to "Back", payments_path, class: "btn btn-secondary" %>
    <%= button_to "Destroy", @payment, method: :delete, class: "btn btn-danger" %>
  </div>
</div>

<%= form_with(model: clinic_service) do |form| %>
  <%= render "shared/form_errors", model: clinic_service %>

  <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
    <div>
      <%= form.label :name, class: "input-label" %>
      <%= form.text_field :name, class: "input-field" %>
    </div>
    <div>
      <%= form.label :base_price, class: "input-label" %>
      <%= form.number_field :base_price, step: 0.01, class: "input-field" %>
    </div>
    <div>
      <%= form.label :duration_minutes, class: "input-label" %>
      <%= form.number_field :duration_minutes, class: "input-field" %>
    </div>
    <div>
      <%= form.label :preparation_minutes, "Preparation time", class: "input-label" %>
      <%= form.number_field :preparation_minutes, class: "input-field", min: 0 %>
    </div>
    <div class="flex items-end gap-2">
      <%= form.check_box :active %>
      <%= form.label :active, class: "input-label mb-0" %>
    </div>
    <div class="md:col-span-2">
      <%= form.label :description, class: "input-label" %>
      <%= form.text_area :description, class: "input-field" %>
    </div>
  </div>

  <div class="mt-4"><%= form.submit class: "btn btn-primary" %></div>
<% end %>

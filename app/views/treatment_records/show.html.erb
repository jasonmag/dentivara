<% content_for :title, "Treatment record" %>

<div class="app-card">
  <%= render @treatment_record %>

  <div class="mt-6 flex flex-wrap gap-2">
    <%= link_to "Edit this treatment record", edit_treatment_record_path(@treatment_record), class: "btn btn-primary" %>
    <%= link_to "Back to treatment records", treatment_records_path, class: "btn btn-secondary" %>
    <%= button_to "Destroy this treatment record", @treatment_record, method: :delete, class: "btn btn-danger" %>
  </div>
</div>

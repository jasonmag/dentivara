<% content_for :title, "Invoice" %>

<div class="app-card">
  <%= render @invoice %>

  <div class="mt-6 flex flex-wrap gap-2">
    <%= link_to "Edit this invoice", edit_invoice_path(@invoice), class: "btn btn-primary" %>
    <%= link_to "Back to invoices", invoices_path, class: "btn btn-secondary" %>
    <%= button_to "Destroy this invoice", @invoice, method: :delete, class: "btn btn-danger" %>
  </div>
</div>

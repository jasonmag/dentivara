<%= form_with(model: patient) do |form| %>
  <%= render "shared/form_errors", model: patient %>

  <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
    <div>
      <%= form.label :first_name, class: "input-label" %>
      <%= form.text_field :first_name, class: "input-field" %>
    </div>
    <div>
      <%= form.label :last_name, class: "input-label" %>
      <%= form.text_field :last_name, class: "input-field" %>
    </div>
    <div>
      <%= form.label :birth_date, class: "input-label" %>
      <%= form.date_field :birth_date, class: "input-field" %>
    </div>
    <div>
      <%= form.label :phone, class: "input-label" %>
      <%= form.text_field :phone, class: "input-field" %>
    </div>
    <div>
      <%= form.label :email, class: "input-label" %>
      <%= form.email_field :email, class: "input-field" %>
    </div>
    <div>
      <%= form.label :consented_at, class: "input-label" %>
      <%= form.datetime_field :consented_at, class: "input-field" %>
    </div>
    <div>
      <%= form.label :emergency_contact_name, class: "input-label" %>
      <%= form.text_field :emergency_contact_name, class: "input-field" %>
    </div>
    <div>
      <%= form.label :emergency_contact_phone, class: "input-label" %>
      <%= form.text_field :emergency_contact_phone, class: "input-field" %>
    </div>
    <div class="md:col-span-2">
      <%= form.label :medical_history, class: "input-label" %>
      <%= form.textarea :medical_history, class: "input-field" %>
    </div>
  </div>

  <div class="mt-4">
    <%= form.submit class: "btn btn-primary" %>
  </div>
<% end %>

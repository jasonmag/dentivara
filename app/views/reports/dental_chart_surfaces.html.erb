<% content_for :title, "Dental Surface Report" %>

<div class="space-y-8">
  <section class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
    <div>
      <h1 class="page-title">Dental Surface Report</h1>
      <p class="serene-subheading mt-1">Filter structured odontogram marks by status, tooth number, and surface.</p>
    </div>
    <%= link_to "Back to Patients", patients_path, class: "btn btn-secondary" %>
  </section>

  <section class="rounded-3xl border border-sky-100 bg-white/90 p-5 shadow-sm">
    <%= form_with url: dental_chart_surfaces_report_path, method: :get, local: true, class: "grid grid-cols-1 gap-3 md:grid-cols-4" do %>
      <div>
        <label for="report_status" class="input-label">Status</label>
        <%= select_tag :status, options_for_select([["All statuses", ""]] + DentalChartEntry::SURFACE_STATUSES.map { |s| [s.humanize, s] }, @status_filter), id: "report_status", class: "input-field" %>
      </div>
      <div>
        <label for="report_tooth" class="input-label">Tooth</label>
        <%= text_field_tag :tooth, @tooth_filter, id: "report_tooth", class: "input-field", placeholder: "e.g., 16 or 31" %>
      </div>
      <div>
        <label for="report_surface" class="input-label">Surface</label>
        <%= select_tag :surface, options_for_select([["All surfaces", ""], ["M", "M"], ["O", "O"], ["D", "D"], ["B", "B"], ["L", "L"]], @surface_filter), id: "report_surface", class: "input-field" %>
      </div>
      <div class="flex items-end gap-2">
        <%= submit_tag "Apply", class: "btn btn-primary px-5 py-2.5" %>
        <%= link_to "Reset", dental_chart_surfaces_report_path, class: "btn btn-secondary px-5 py-2.5" %>
      </div>
    <% end %>
  </section>

  <section class="table-shell">
    <table class="data-table">
      <thead>
        <tr>
          <th>Patient</th>
          <th>Recorded On</th>
          <th>Matched Surface Marks</th>
          <th>Recorded By</th>
          <th class="text-right">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if @matched_rows.any? %>
          <% @matched_rows.each do |row| %>
            <tr>
              <td>
                <div class="font-semibold text-stone-800"><%= row[:patient].full_name %></div>
                <div class="text-xs text-stone-500"><%= row[:patient].email.presence || "No email" %></div>
              </td>
              <td><%= l(row[:entry].recorded_on, format: :long) %></td>
              <td>
                <div class="space-y-1 text-xs text-stone-700">
                  <% row[:marks].each do |mark| %>
                    <div><span class="font-semibold"><%= mark["tooth"] %>-<%= mark["surface"] %></span>: <%= mark["status"].to_s.humanize %></div>
                  <% end %>
                </div>
              </td>
              <td><%= row[:recorded_by].name %></td>
              <td class="text-right">
                <%= link_to "Patient", patient_path(row[:patient]), class: "btn btn-secondary px-3 py-1.5 text-xs" %>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="5" class="py-10 text-center text-sm text-stone-500">No chart surface matches found for the current filter.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </section>
</div>

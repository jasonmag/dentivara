<% content_for :title, "Document Templates" %>
<div class="space-y-8">
  <section class="flex items-end justify-between">
    <div><h1 class="page-title">Document Templates</h1><p class="serene-subheading mt-1">Prescription and certificate templates with digital signature fields.</p></div>
    <%= link_to "New Template", new_document_template_path, class: "btn btn-primary" %>
  </section>
  <section class="table-shell"><table class="data-table"><thead><tr><th>Name</th><th>Kind</th><th>Status</th><th class="text-right">Actions</th></tr></thead><tbody><% @document_templates.each do |template| %><tr><td class="font-semibold text-stone-800"><%= template.name %></td><td><%= template.kind.humanize %></td><td><%= template.active? ? "Active" : "Inactive" %></td><td class="text-right"><%= link_to "View", document_template_path(template), class: "btn btn-secondary px-3 py-1.5 text-xs" %></td></tr><% end %></tbody></table></section>
</div>

<% content_for :title, "Document Template" %>
<div class="space-y-4">
  <div class="app-card kv-grid">
    <div class="kv-item"><p class="kv-label">Name</p><p class="kv-value"><%= @document_template.name %></p></div>
    <div class="kv-item"><p class="kv-label">Kind</p><p class="kv-value"><%= @document_template.kind.humanize %></p></div>
    <div class="kv-item"><p class="kv-label">Signature Name</p><p class="kv-value"><%= @document_template.digital_signature_name.presence || "N/A" %></p></div>
    <div class="kv-item"><p class="kv-label">Signature Title</p><p class="kv-value"><%= @document_template.digital_signature_title.presence || "N/A" %></p></div>
    <div class="kv-item sm:col-span-2"><p class="kv-label">Header</p><p class="kv-value whitespace-pre-line"><%= @document_template.header_text %></p></div>
    <div class="kv-item sm:col-span-2"><p class="kv-label">Body Template</p><p class="kv-value whitespace-pre-line"><%= @document_template.body_template %></p></div>
    <div class="kv-item sm:col-span-2"><p class="kv-label">Footer</p><p class="kv-value whitespace-pre-line"><%= @document_template.footer_text %></p></div>
  </div>
  <div class="flex flex-wrap gap-2">
    <%= link_to "Preview", preview_document_template_path(@document_template), class: "btn btn-secondary" %>
    <%= link_to "Edit", edit_document_template_path(@document_template), class: "btn btn-primary" %>
    <%= link_to "Back", document_templates_path, class: "btn btn-secondary" %>
    <%= button_to "Destroy", @document_template, method: :delete, class: "btn btn-danger" %>
  </div>
</div>

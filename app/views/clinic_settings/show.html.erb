<% content_for :title, "Clinic Settings" %>

<div class="space-y-6">
  <section class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
    <div>
      <h1 class="page-title">Clinic Settings</h1>
      <p class="serene-subheading mt-1">Set clinic-wide defaults used across schedules and appointment times.</p>
    </div>
    <%= link_to "Back to User Settings", users_path, class: "btn btn-secondary" %>
  </section>

  <section class="serene-card p-6">
    <%= form_with model: @clinic_setting, url: clinic_settings_path, method: :patch, class: "space-y-5" do |form| %>
      <%= render "shared/form_errors", model: @clinic_setting %>

      <div>
        <h2 class="text-sm font-semibold uppercase tracking-wide text-stone-600">Scheduling Settings</h2>
        <div class="mt-3">
          <%= form.label :time_zone, "Clinic timezone", class: "input-label" %>
          <%= form.select :time_zone, ClinicSetting.time_zone_options, {}, class: "input-field" %>
          <p class="mt-2 text-xs text-stone-500">Appointment scheduling, available slots, reminders, and date/time displays use this timezone.</p>
        </div>
      </div>

      <div class="rounded-xl border border-[#8BA88E]/30 bg-[#F7FBF7] p-4">
        <h2 class="text-sm font-semibold uppercase tracking-wide text-[#4a654e]">Billing Settings</h2>
        <div class="mt-3">
          <%= form.label :currency_code, "Clinic default currency", class: "input-label" %>
          <%= form.select :currency_code, ClinicSetting.currency_options_for_select, {}, class: "input-field" %>
          <p class="mt-2 text-xs text-stone-600">Applies globally to invoices, services pricing, appointment billing, payment summaries, and dashboard financial metrics.</p>
        </div>
      </div>

      <div class="rounded-xl border border-blue-100 bg-blue-50/40 p-4">
        <h2 class="text-sm font-semibold uppercase tracking-wide text-blue-800">Queue ETA Settings</h2>
        <p class="mt-1 text-xs text-blue-700">Configure average handling minutes used by the Reception Queue Board ETA.</p>
        <div class="mt-3 grid grid-cols-1 gap-3 md:grid-cols-2">
          <div>
            <%= form.label :queue_eta_minutes_default, "Default ETA minutes per patient", class: "input-label" %>
            <%= form.number_field :queue_eta_minutes_default, min: 1, max: 180, class: "input-field" %>
          </div>
          <div>
            <%= form.label :queue_eta_minutes_scheduled, "Scheduled patient minutes", class: "input-label" %>
            <%= form.number_field :queue_eta_minutes_scheduled, min: 1, max: 180, class: "input-field" %>
          </div>
          <div>
            <%= form.label :queue_eta_minutes_walk_in, "Walk-in patient minutes", class: "input-label" %>
            <%= form.number_field :queue_eta_minutes_walk_in, min: 1, max: 180, class: "input-field" %>
          </div>
          <div>
            <%= form.label :queue_eta_minutes_emergency, "Emergency patient minutes", class: "input-label" %>
            <%= form.number_field :queue_eta_minutes_emergency, min: 1, max: 180, class: "input-field" %>
          </div>
          <div>
            <%= form.label :queue_eta_minutes_priority, "Priority patient minutes", class: "input-label" %>
            <%= form.number_field :queue_eta_minutes_priority, min: 1, max: 180, class: "input-field" %>
          </div>
        </div>
      </div>

      <div class="rounded-xl border border-stone-100 bg-stone-50 p-4 text-sm text-stone-700">
        <p class="font-semibold text-stone-800">Current clinic time</p>
        <p class="mt-1"><%= l(Time.current, format: :long) %> (<%= Time.zone.tzinfo.name %>)</p>
      </div>

      <%= form.submit "Save Settings", class: "btn btn-primary" %>
    <% end %>
  </section>
</div>

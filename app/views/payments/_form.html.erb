<%= form_with(model: payment) do |form| %>
  <%= render "shared/form_errors", model: payment %>

  <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
    <div>
      <%= form.label :invoice_id, class: "input-label" %>
      <%= form.collection_select :invoice_id, Invoice.order(updated_at: :desc), :id, :id, { prompt: "Select invoice" }, class: "input-field" %>
    </div>
    <div>
      <%= form.label :amount, class: "input-label" %>
      <%= form.number_field :amount, step: 0.01, class: "input-field" %>
    </div>
    <div>
      <%= form.label :paid_on, class: "input-label" %>
      <%= form.date_field :paid_on, class: "input-field" %>
    </div>
    <div>
      <%= form.label :method, class: "input-label" %>
      <%= form.text_field :method, class: "input-field" %>
    </div>
    <div class="md:col-span-2">
      <%= form.label :reference_code, class: "input-label" %>
      <%= form.text_field :reference_code, class: "input-field" %>
    </div>
  </div>

  <div class="mt-4">
    <%= form.submit class: "btn btn-primary" %>
  </div>
<% end %>

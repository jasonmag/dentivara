<% if defined?(@available_slots_by_date) && @available_slots_by_date.present? %>
  <section class="mt-5 rounded-2xl border border-stone-100 bg-stone-50 p-4 shadow-sm">
    <div class="flex flex-col gap-3 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[#6B8F73]">Available Slots</p>
        <h3 class="font-serif text-2xl text-stone-800">Choose an exact appointment time</h3>
        <p class="mt-1 text-sm text-stone-500">
          <% if @slot_view == "month" %>
            <%= @slot_date.strftime("%B %Y") %>
          <% else %>
            <%= @slot_range.first.strftime("%b %d") %> to <%= @slot_range.last.strftime("%b %d, %Y") %>
          <% end %>
        </p>
      </div>

      <div class="flex flex-wrap gap-2">
        <button type="button" data-action="appointment-wizard#previousSlotRange" class="btn btn-secondary px-3 py-1.5 text-xs">Previous</button>
        <button type="button" data-action="appointment-wizard#changeSlotView" data-slot-view="week" class="btn <%= @slot_view == "week" ? "btn-primary" : "btn-secondary" %> px-3 py-1.5 text-xs">Week</button>
        <button type="button" data-action="appointment-wizard#changeSlotView" data-slot-view="month" class="btn <%= @slot_view == "month" ? "btn-primary" : "btn-secondary" %> px-3 py-1.5 text-xs">Month</button>
        <button type="button" data-action="appointment-wizard#nextSlotRange" class="btn btn-secondary px-3 py-1.5 text-xs">Next</button>
      </div>
    </div>

    <div class="mt-4 grid gap-3 rounded-2xl border border-stone-100 bg-white p-4 lg:grid-cols-2">
      <div>
        <p class="text-xs font-semibold uppercase tracking-wide text-stone-500">Earliest Available Appointment</p>
        <% if @earliest_available_slot.present? %>
          <p class="mt-1 text-lg font-semibold text-stone-800">
            <%= l(@earliest_available_slot[:starts_at], format: "%a, %b %d") %>
          </p>
          <p class="text-sm text-stone-600">
            <%= l(@earliest_available_slot[:starts_at], format: "%I:%M %p") %> -
            <%= l(@earliest_available_slot[:ends_at], format: "%I:%M %p") %>
          </p>
        <% else %>
          <p class="mt-1 text-sm text-stone-500">No available appointments in this range.</p>
        <% end %>
      </div>

      <div class="rounded-xl bg-[#F9F7EF] px-4 py-3">
        <p class="text-xs font-semibold uppercase tracking-wide text-[#8B7A3C]">Smart Availability</p>
        <p class="mt-1 text-sm text-stone-700">
          Only valid appointment times are shown based on service duration, dentist schedule, and clinic capacity.
        </p>
        <p class="mt-2 text-xs text-stone-500"><%= pluralize(@available_slots_count.to_i, "open slot") %> available in this range.</p>
      </div>
    </div>

    <% if @available_slots_count.to_i.zero? %>
      <div class="mt-4 rounded-2xl border border-stone-200 bg-white px-4 py-5 text-center">
        <p class="text-base font-semibold text-stone-800">No slots available</p>
        <p class="mt-1 text-sm text-stone-500">Try another date, dentist, or time preference.</p>
      </div>
    <% end %>

    <div class="mt-4 grid grid-flow-col auto-cols-[minmax(17rem,1fr)] gap-3 overflow-x-auto pb-2 md:auto-cols-[minmax(18rem,1fr)] lg:auto-cols-[minmax(19rem,1fr)]">
      <% @available_slots_by_date.each do |date, slots| %>
        <% available_slots = slots.select { |slot| slot[:status] == "available" } %>
        <% recommended_slots = available_slots.select { |slot| slot[:recommended] } %>
        <% remaining_slots = available_slots.reject { |slot| slot[:recommended] } %>
        <% morning_slots = remaining_slots.select { |slot| slot[:period] == "morning" } %>
        <% afternoon_slots = remaining_slots.select { |slot| slot[:period] == "afternoon" } %>

        <div class="rounded-2xl border border-stone-100 bg-white p-3 shadow-sm">
          <div class="flex items-start justify-between gap-3 border-b border-stone-100 pb-3">
            <div>
              <p class="text-sm font-semibold text-stone-800"><%= date.strftime("%a") %></p>
              <p class="text-xs text-stone-500"><%= date.strftime("%b %d") %></p>
            </div>
            <span class="rounded-full bg-stone-50 px-2 py-1 text-[11px] font-semibold text-stone-500"><%= pluralize(available_slots.size, "slot") %></span>
          </div>

          <% if available_slots.blank? %>
            <div class="mt-4 rounded-xl border border-stone-100 bg-stone-50 px-3 py-4 text-center">
              <p class="text-sm font-medium text-stone-500">No slots</p>
              <p class="mt-1 text-xs text-stone-400">This day is fully blocked or outside the current filters.</p>
            </div>
          <% else %>
            <div class="mt-4 space-y-4">
              <% if recommended_slots.any? %>
                <div>
                  <div class="mb-2 flex items-center justify-between">
                    <p class="text-xs font-semibold uppercase tracking-wide text-[#6B8F73]">Recommended</p>
                    <p class="text-[11px] text-stone-400">Best available times</p>
                  </div>

                  <div class="flex flex-wrap gap-2">
                    <% recommended_slots.each do |slot| %>
                      <%= render "appointments/slot_chip", slot: slot, appointment: @appointment, selected_service: @selected_service, total_minutes: @slot_total_minutes, recommended: true %>
                    <% end %>
                  </div>
                </div>
              <% end %>

              <% [["morning", morning_slots], ["afternoon", afternoon_slots]].each do |period, period_slots| %>
                <% next if period_slots.blank? %>
                <% visible_slots = period_slots.first(3) %>
                <% hidden_slots = period_slots.drop(3) %>

                <div>
                  <div class="mb-2 flex items-center justify-between">
                    <p class="text-xs font-semibold uppercase tracking-wide text-stone-500"><%= slot_chip_period_label(period) %></p>
                    <p class="text-[11px] text-stone-400"><%= pluralize(period_slots.count, "time") %></p>
                  </div>

                  <div class="flex flex-wrap gap-2">
                    <% visible_slots.each do |slot| %>
                      <%= render "appointments/slot_chip", slot: slot, appointment: @appointment, selected_service: @selected_service, total_minutes: @slot_total_minutes, recommended: false %>
                    <% end %>
                  </div>

                  <% if hidden_slots.any? %>
                    <details class="mt-2">
                      <summary class="cursor-pointer text-xs font-medium text-[#6B8F73] transition hover:text-[#4F7458]">+ <%= hidden_slots.size %> more times</summary>
                      <div class="mt-3 flex flex-wrap gap-2">
                        <% hidden_slots.each do |slot| %>
                          <%= render "appointments/slot_chip", slot: slot, appointment: @appointment, selected_service: @selected_service, total_minutes: @slot_total_minutes, recommended: false %>
                        <% end %>
                      </div>
                    </details>
                  <% end %>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </section>
<% end %>

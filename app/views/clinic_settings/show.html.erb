<% content_for :title, "Clinic Settings" %>

<div class="space-y-6">
  <section class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
    <div>
      <h1 class="page-title">Clinic Settings</h1>
      <p class="serene-subheading mt-1">Set clinic-wide defaults used across schedules and appointment times.</p>
    </div>
    <%= link_to "Back to User Settings", users_path, class: "btn btn-secondary" %>
  </section>

  <section class="serene-card p-6">
    <%= form_with model: @clinic_setting, url: clinic_settings_path, method: :patch, class: "space-y-5" do |form| %>
      <%= render "shared/form_errors", model: @clinic_setting %>

      <div>
        <%= form.label :time_zone, "Clinic timezone", class: "input-label" %>
        <%= form.select :time_zone, ClinicSetting.time_zone_options, {}, class: "input-field" %>
        <p class="mt-2 text-xs text-stone-500">Appointment scheduling, available slots, reminders, and date/time displays use this timezone.</p>
      </div>

      <div class="rounded-xl border border-stone-100 bg-stone-50 p-4 text-sm text-stone-700">
        <p class="font-semibold text-stone-800">Current clinic time</p>
        <p class="mt-1"><%= l(Time.current, format: :long) %> (<%= Time.zone.tzinfo.name %>)</p>
      </div>

      <%= form.submit "Save Settings", class: "btn btn-primary" %>
    <% end %>
  </section>
</div>

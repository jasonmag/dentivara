<% content_for :title, "Notification" %>

<div class="space-y-4">
  <div class="app-card">
    <%= render @notification %>
  </div>

  <div class="flex flex-wrap gap-2">
    <% if can_access_feature?(:notifications, :update) %>
      <%= link_to "Edit", edit_notification_path(@notification), class: "btn btn-primary" %>
    <% end %>
    <%= link_to "Back", notifications_path, class: "btn btn-secondary" %>
    <% if can_access_feature?(:notifications, :destroy) %>
      <%= button_to "Destroy", @notification, method: :delete, class: "btn btn-danger" %>
    <% end %>
  </div>
</div>

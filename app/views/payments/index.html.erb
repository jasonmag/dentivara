<% content_for :title, "Payments" %>

<div class="space-y-8">
  <section class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
    <div>
      <h1 class="page-title">Payment Ledger</h1>
      <p class="serene-subheading mt-1">Track collections and references across all invoices.</p>
    </div>
    <div class="flex gap-3">
      <% if can_access_feature?(:invoices, :view) %>
        <%= link_to invoices_path, class: "btn btn-secondary" do %>
          Back to Invoices
        <% end %>
      <% end %>
      <% if can_access_feature?(:payments, :create) %>
        <%= link_to new_payment_path, class: "btn btn-primary" do %>
          New Payment
        <% end %>
      <% end %>
    </div>
  </section>

  <section class="table-shell">
    <table class="data-table">
      <thead>
        <tr>
          <th>Payment ID</th>
          <th>Invoice</th>
          <th>Patient</th>
          <th>Amount</th>
          <th>Method</th>
          <th>Paid On</th>
          <th>Reference</th>
          <th class="text-right">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @payments.each do |payment| %>
          <tr>
            <td class="font-semibold text-stone-800">#<%= payment.id %></td>
            <td>#<%= payment.invoice_id %></td>
            <td><%= payment.invoice.patient.full_name %></td>
            <td><%= clinic_number_to_currency(payment.amount) %></td>
            <td><%= payment.method.present? ? payment.method.humanize : "N/A" %></td>
            <td><%= payment.paid_on.present? ? l(payment.paid_on, format: :long) : 'N/A' %></td>
            <td><%= payment.reference_code.presence || 'N/A' %></td>
            <td class="text-right">
              <% if can_access_feature?(:payments, :view) %>
                <%= link_to "View", payment_path(payment), class: "btn btn-secondary px-3 py-1.5 text-xs" %>
                <%= link_to "Receipt PDF", receipt_payment_path(payment), class: "btn btn-secondary px-3 py-1.5 text-xs", data: { turbo: false } %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </section>
</div>

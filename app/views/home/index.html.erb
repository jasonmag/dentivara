<section class="mb-6 rounded-2xl border border-slate-300 bg-white p-6 shadow-[0_8px_20px_rgba(43,108,176,0.08)]">
  <h2 class="text-2xl font-bold tracking-tight text-[#003e6b]">Dental Clinic Management System</h2>
  <p class="mt-2 text-sm text-slate-600">Hotwire-enabled MVP for patient operations, schedules, treatment records, and billing workflows.</p>
</section>

<section class="mb-4 grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-4">
  <article class="rounded-2xl border border-slate-300 bg-white p-4 shadow-[0_4px_12px_rgba(43,108,176,0.06)]">
    <h3 class="text-sm font-semibold text-slate-500">Total Patients</h3>
    <p class="mt-2 text-2xl font-bold text-[#003e6b]"><%= @stats[:patients] %></p>
  </article>
  <article class="rounded-2xl border border-slate-300 bg-white p-4 shadow-[0_4px_12px_rgba(43,108,176,0.06)]">
    <h3 class="text-sm font-semibold text-slate-500">Appointments Today</h3>
    <p class="mt-2 text-2xl font-bold text-[#003e6b]"><%= @stats[:appointments_today] %></p>
  </article>
  <article class="rounded-2xl border border-slate-300 bg-white p-4 shadow-[0_4px_12px_rgba(43,108,176,0.06)]">
    <h3 class="text-sm font-semibold text-slate-500">Treatments This Month</h3>
    <p class="mt-2 text-2xl font-bold text-[#003e6b]"><%= @stats[:treatments_this_month] %></p>
  </article>
  <article class="rounded-2xl border border-slate-300 bg-white p-4 shadow-[0_4px_12px_rgba(43,108,176,0.06)]">
    <h3 class="text-sm font-semibold text-slate-500">Outstanding Balance</h3>
    <p class="mt-2 text-2xl font-bold text-[#003e6b]"><%= number_to_currency(@stats[:outstanding_balance]) %></p>
  </article>
</section>

<section class="mb-4 rounded-2xl border border-slate-300 bg-white p-4 shadow-[0_4px_12px_rgba(43,108,176,0.06)]">
  <div class="mb-3 flex items-center justify-between">
    <h3 class="text-lg font-semibold text-[#003e6b]">Schedule Calendar</h3>
    <p class="text-sm font-medium text-slate-500"><%= @calendar_month_label %></p>
  </div>

  <div class="mb-2 grid grid-cols-7 gap-2 text-center text-xs font-semibold uppercase text-slate-500">
    <% %w[Sun Mon Tue Wed Thu Fri Sat].each do |weekday| %>
      <div><%= weekday %></div>
    <% end %>
  </div>

  <div class="grid grid-cols-1 gap-2 sm:grid-cols-2 lg:grid-cols-4 xl:grid-cols-7">
    <% @calendar_days.each do |day| %>
      <% day_appointments = @calendar_appointments_by_day.fetch(day, []) %>
      <article class="min-h-40 rounded-xl border border-slate-200 p-2 <%= day.month == Time.zone.today.month ? 'bg-white' : 'bg-slate-50' %>">
        <div class="mb-2 flex items-center justify-between">
          <p class="text-sm font-semibold <%= day == Time.zone.today ? 'text-[#003e6b]' : 'text-slate-700' %>"><%= day.day %></p>
          <% if day == Time.zone.today %>
            <span class="rounded-full bg-sky-100 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-sky-700">Today</span>
          <% end %>
        </div>

        <div class="space-y-1">
          <% if day_appointments.any? %>
            <% day_appointments.each do |appointment| %>
              <div class="rounded-md border border-slate-200 bg-slate-50 px-2 py-1 text-[11px]">
                <p class="font-semibold text-slate-700">
                  <%= l(appointment.starts_at, format: "%I:%M %p") %>
                  <span class="font-normal text-slate-500">- <%= appointment.status.humanize %></span>
                </p>
                <p class="truncate text-slate-600"><%= appointment.patient.full_name %></p>
                <p class="truncate text-slate-500"><%= appointment.user.name %></p>
              </div>
            <% end %>
          <% else %>
            <p class="text-[11px] text-slate-400">No schedules</p>
          <% end %>
        </div>
      </article>
    <% end %>
  </div>
</section>

<section class="grid grid-cols-1 gap-4 xl:grid-cols-2">
  <article class="rounded-2xl border border-slate-300 bg-white p-4 shadow-[0_4px_12px_rgba(43,108,176,0.06)]">
    <h3 class="mb-3 text-lg font-semibold text-[#003e6b]">Upcoming Appointments</h3>
    <div class="overflow-x-auto">
      <table class="min-w-full text-sm">
        <thead class="text-left text-xs uppercase text-slate-500">
          <tr>
            <th class="border-b border-slate-200 px-3 py-2">Patient</th>
            <th class="border-b border-slate-200 px-3 py-2">Dentist</th>
            <th class="border-b border-slate-200 px-3 py-2">Time</th>
            <th class="border-b border-slate-200 px-3 py-2">Status</th>
          </tr>
        </thead>
        <tbody>
          <% @upcoming_appointments.each do |appointment| %>
            <tr class="odd:bg-slate-50/50">
              <td class="border-b border-slate-100 px-3 py-2"><%= appointment.patient.full_name %></td>
              <td class="border-b border-slate-100 px-3 py-2"><%= appointment.user.name %></td>
              <td class="border-b border-slate-100 px-3 py-2"><%= l(appointment.starts_at, format: :short) %></td>
              <td class="border-b border-slate-100 px-3 py-2"><%= appointment.status.humanize %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </article>

  <article class="rounded-2xl border border-slate-300 bg-white p-4 shadow-[0_4px_12px_rgba(43,108,176,0.06)]">
    <h3 class="mb-3 text-lg font-semibold text-[#003e6b]">Recent Invoices</h3>
    <div class="overflow-x-auto">
      <table class="min-w-full text-sm">
        <thead class="text-left text-xs uppercase text-slate-500">
          <tr>
            <th class="border-b border-slate-200 px-3 py-2">Patient</th>
            <th class="border-b border-slate-200 px-3 py-2">Status</th>
            <th class="border-b border-slate-200 px-3 py-2">Total</th>
            <th class="border-b border-slate-200 px-3 py-2">Balance</th>
          </tr>
        </thead>
        <tbody>
          <% @recent_invoices.each do |invoice| %>
            <tr class="odd:bg-slate-50/50">
              <td class="border-b border-slate-100 px-3 py-2"><%= invoice.patient.full_name %></td>
              <td class="border-b border-slate-100 px-3 py-2"><%= invoice.status.humanize %></td>
              <td class="border-b border-slate-100 px-3 py-2"><%= number_to_currency(invoice.total_amount) %></td>
              <td class="border-b border-slate-100 px-3 py-2"><%= number_to_currency(invoice.balance_amount) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </article>
</section>

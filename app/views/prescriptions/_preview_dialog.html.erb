<% rendered_prescription = prescription_preview_payload(patient, prescription) %>

<div data-controller="modal">
  <button type="button" class="btn btn-secondary px-3 py-1.5 text-xs" data-action="modal#open">Preview</button>

  <dialog
    data-modal-target="dialog"
    data-action="click->modal#closeOnBackdrop"
    class="m-auto w-[92vw] max-w-3xl rounded-2xl border border-stone-200 p-0 backdrop:bg-black/50"
  >
    <div class="flex items-center justify-between border-b border-stone-200 px-4 py-3">
      <h3 class="font-semibold text-stone-800">Prescription Preview</h3>
      <div class="flex items-center gap-2">
        <button type="button" class="btn btn-secondary px-3 py-1.5 text-xs" data-action="modal#print">Print</button>
        <button type="button" class="btn btn-secondary px-3 py-1.5 text-xs" data-action="modal#close">Close</button>
      </div>
    </div>
    <div class="bg-stone-50 p-4">
      <div data-modal-target="printArea">
        <%= render "shared/prescription_sheet",
          template: prescription.document_template,
          rendered: rendered_prescription,
          signature_image: prescription.signature_image,
          signature_name: prescription.signed_by_user&.name || prescription.drafted_by_user.name,
          signature_title: "Licensed Dentist" %>
      </div>
    </div>
  </dialog>
</div>

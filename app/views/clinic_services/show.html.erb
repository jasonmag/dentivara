<% content_for :title, "Clinic Service" %>
<div class="space-y-4">
  <div class="app-card kv-grid">
    <div class="kv-item"><p class="kv-label">Name</p><p class="kv-value"><%= @clinic_service.name %></p></div>
    <div class="kv-item"><p class="kv-label">Base Price</p><p class="kv-value"><%= number_to_currency(@clinic_service.base_price) %></p></div>
    <div class="kv-item"><p class="kv-label">Duration</p><p class="kv-value"><%= @clinic_service.duration_minutes %> minutes</p></div>
    <div class="kv-item"><p class="kv-label">Status</p><p class="kv-value"><%= @clinic_service.active? ? "Active" : "Inactive" %></p></div>
    <div class="kv-item sm:col-span-2"><p class="kv-label">Description</p><p class="kv-value"><%= @clinic_service.description.presence || "N/A" %></p></div>
  </div>
  <div class="flex flex-wrap gap-2">
    <%= link_to "Edit", edit_clinic_service_path(@clinic_service), class: "btn btn-primary" %>
    <%= link_to "Back", clinic_services_path, class: "btn btn-secondary" %>
    <%= button_to "Destroy", @clinic_service, method: :delete, class: "btn btn-danger" %>
  </div>
</div>

<div class="mx-auto mt-20 max-w-md">
  <div class="app-card">
    <h1 class="mb-4 font-serif text-2xl text-stone-800">Dentivara Login</h1>
    <%= form_with url: login_path, method: :post, class: "space-y-4" do |form| %>
      <div>
        <%= form.label :email, class: "input-label" %>
        <%= form.email_field :email, class: "input-field", required: true %>
      </div>
      <div>
        <%= form.label :password, class: "input-label" %>
        <%= form.password_field :password, class: "input-field", required: true %>
      </div>
      <%= form.submit "Sign in", class: "btn btn-primary" %>
    <% end %>
  </div>
</div>

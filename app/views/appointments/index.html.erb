<% content_for :title, "Appointments" %>

<div class="space-y-8" data-controller="appointment-modal">
  <% if @selected_date.present? %>
    <section class="serene-card p-5">
      <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
        <div>
          <p class="text-xs font-semibold uppercase tracking-wider text-stone-500">Calendar Day View</p>
          <h2 class="font-serif text-2xl text-stone-800"><%= @selected_date.strftime("%A, %B %d, %Y") %></h2>
        </div>
        <%= link_to "Clear Day Filter", appointments_path, class: "btn btn-secondary" %>
      </div>

      <div class="mt-4 space-y-2">
        <% if @selected_day_appointments.any? %>
          <% @selected_day_appointments.each do |appointment| %>
            <div class="rounded-lg border border-stone-100 bg-stone-50 p-3">
              <div class="flex items-center justify-between gap-3">
                <p class="font-semibold text-stone-800"><%= appointment.patient.full_name %></p>
                <p class="text-xs font-semibold uppercase tracking-wide text-stone-500"><%= appointment.status.humanize %></p>
              </div>
              <p class="text-xs text-stone-600"><%= l(appointment.starts_at, format: "%I:%M %p") %> to <%= l(appointment.ends_at, format: "%I:%M %p") %> • <%= appointment.booking_type.humanize %> with <%= appointment.user.name %></p>
            </div>
          <% end %>
        <% else %>
          <p class="text-sm text-stone-500">No appointments scheduled for this date.</p>
        <% end %>
      </div>
    </section>
  <% end %>

  <section class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
    <div>
      <h1 class="page-title">Weekly Schedule</h1>
    </div>
    <% if can_access_feature?(:appointments, :create) %>
      <div class="flex flex-wrap gap-2">
        <%= link_to schedule_settings_path, class: "btn btn-secondary gap-2 px-5 py-3" do %>
          <span class="material-symbols-outlined">tune</span>
          <span>Schedule Rules</span>
        <% end %>
        <%= link_to new_appointment_path, class: "btn btn-primary gap-2 px-6 py-3" do %>
          <span class="material-symbols-outlined">add</span>
          <span>New Appointment</span>
        <% end %>
      </div>
    <% end %>
  </section>

  <%= turbo_frame_tag "weekly_schedule" do %>
    <%= render "weekly_schedule" %>
  <% end %>

  <dialog
    data-appointment-modal-target="dialog"
    data-action="click->appointment-modal#closeOnBackdrop cancel->appointment-modal#close"
    class="m-auto w-[92vw] max-w-5xl rounded-2xl border border-stone-200 p-0 backdrop:bg-black/50"
  >
    <div class="bg-white px-4 py-4 sm:px-6">
      <div data-appointment-modal-target="content"></div>
    </div>
  </dialog>
</div>

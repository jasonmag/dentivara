<section id="queue_board" class="grid gap-6 xl:grid-cols-3">
  <article class="serene-card p-6 xl:col-span-2">
    <div class="mb-4 flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
      <h2 class="font-serif text-2xl text-stone-800">Live Queue</h2>
      <% settings = ClinicSetting.current %>
      <div class="rounded-xl border border-blue-100 bg-blue-50 px-3 py-2 text-xs text-blue-800">
        <p class="font-semibold">ETA Formula</p>
        <p class="mt-1">Wait = (queue position - 1) x queue-type minutes</p>
        <p class="mt-1">
          Scheduled: <%= settings.queue_eta_minutes_scheduled %>m |
          Walk-in: <%= settings.queue_eta_minutes_walk_in %>m |
          Emergency: <%= settings.queue_eta_minutes_emergency %>m |
          Priority: <%= settings.queue_eta_minutes_priority %>m
        </p>
      </div>
    </div>
    <div class="space-y-3">
      <% queue_entries.each do |entry| %>
        <div class="rounded-xl border border-stone-100 bg-stone-50 p-4">
          <div class="flex flex-col gap-2 md:flex-row md:items-center md:justify-between">
            <div>
              <p class="font-semibold text-stone-900">#<%= entry.position %> • <%= entry.patient.full_name %></p>
              <p class="text-sm text-stone-600">
                <%= entry.queue_type.humanize %> • Priority <%= entry.priority_level %> • <%= entry.status.humanize %>
              </p>
              <p class="text-xs font-semibold text-[#4a654e]"><%= queue_eta_label(entry) %></p>
              <p class="text-xs text-stone-500">Arrived: <%= l(entry.arrived_at, format: :short) %></p>
              <% if entry.notes.present? %><p class="mt-1 text-xs text-stone-600"><%= entry.notes %></p><% end %>
            </div>
            <div class="flex flex-wrap gap-2">
              <% if entry.status == "waiting" %>
                <%= button_to "Call", call_queue_entry_path(entry), method: :patch, class: "btn btn-secondary px-3 py-1.5 text-xs" %>
              <% end %>
              <% if entry.status == "called" %>
                <%= button_to "Serve", serve_queue_entry_path(entry), method: :patch, class: "btn btn-primary px-3 py-1.5 text-xs" %>
              <% end %>
              <%= button_to "Cancel", cancel_queue_entry_path(entry), method: :patch, class: "btn btn-danger px-3 py-1.5 text-xs" %>
            </div>
          </div>
        </div>
      <% end %>
      <% if queue_entries.empty? %>
        <p class="text-sm text-stone-500">No active queue entries right now.</p>
      <% end %>
    </div>
  </article>

  <article class="serene-card p-6">
    <h2 class="mb-4 font-serif text-xl text-stone-800">Add to Queue</h2>
    <%= form_with model: QueueEntry.new, url: queue_entries_path, class: "space-y-3" do |form| %>
      <div>
        <%= form.label :appointment_id, "Appointment (Today)", class: "input-label" %>
        <%= form.collection_select :appointment_id, upcoming_appointments, :id, ->(a) { "#{l(a.starts_at, format: '%I:%M %p')} - #{a.patient.full_name}" }, { include_blank: "None / Walk-in" }, class: "input-field" %>
      </div>
      <div>
        <%= form.label :patient_id, class: "input-label" %>
        <%= form.collection_select :patient_id, Patient.order(:first_name), :id, :full_name, { prompt: "Select patient" }, class: "input-field" %>
      </div>
      <div>
        <%= form.label :queue_type, class: "input-label" %>
        <%= form.select :queue_type, QueueEntry::QUEUE_TYPES.map { |type| [type.humanize, type] }, {}, class: "input-field" %>
      </div>
      <div>
        <%= form.label :priority_level, class: "input-label" %>
        <%= form.number_field :priority_level, in: 0..10, class: "input-field", value: 0 %>
      </div>
      <div>
        <%= form.label :notes, class: "input-label" %>
        <%= form.text_area :notes, rows: 2, class: "input-field" %>
      </div>
      <%= form.submit "Add Patient", class: "btn btn-primary w-full justify-center" %>
    <% end %>
  </article>
</section>

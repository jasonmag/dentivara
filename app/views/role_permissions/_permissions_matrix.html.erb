<% matrix = role_permission.permission_matrix %>
<section class="space-y-4 rounded-2xl border border-stone-200 bg-stone-50 p-4">
  <div>
    <h2 class="font-semibold text-stone-800">RBAC Permissions</h2>
    <p class="mt-1 text-sm text-stone-600">View is enabled by default. Toggle create, update, or delete for the selected role.</p>
  </div>

  <div class="overflow-x-auto">
    <table class="min-w-full border-separate border-spacing-0 text-sm">
      <thead>
        <tr class="text-left text-xs uppercase tracking-wider text-stone-500">
          <th class="px-3 py-2">Feature</th>
          <% User::PERMISSION_ACTIONS.each do |action| %>
            <th class="px-3 py-2 text-center"><%= action.humanize %></th>
          <% end %>
        </tr>
      </thead>
      <tbody>
        <% User::PERMISSION_FEATURES.each do |feature, label| %>
          <tr class="border-t border-stone-200">
            <td class="px-3 py-3 font-medium text-stone-800"><%= label %></td>
            <% User::PERMISSION_ACTIONS.each do |action| %>
              <% field_name = "role_permission[permissions][#{feature}][#{action}]" %>
              <% input_id = "role_permission_permissions_#{feature}_#{action}" %>
              <td class="px-3 py-3 text-center">
                <label for="<%= input_id %>" class="inline-flex cursor-pointer items-center justify-center">
                  <%= check_box_tag field_name, "1", matrix.dig(feature.to_s, action) == true, id: input_id, class: "h-4 w-4 rounded border-stone-300 text-[#2B6CB0] focus:ring-[#2B6CB0]" %>
                </label>
              </td>
            <% end %>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>

<% content_for :title, "Patient" %>

<div class="space-y-4" data-controller="image-preview">
  <div class="app-card">
    <div class="mb-4 flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
      <div>
        <h1 class="font-serif text-2xl text-stone-800"><%= @patient.full_name %></h1>
        <p class="serene-subheading mt-1">Patient record</p>
      </div>
      <% if can_access_feature?(:appointments, :create) %>
        <%= link_to new_appointment_path(patient_id: @patient.id), class: "btn btn-primary gap-2" do %>
          <span class="material-symbols-outlined">add</span>
          <span>New Appointment</span>
        <% end %>
      <% end %>
    </div>

    <%= render @patient %>
  </div>

  <div class="app-card">
    <div class="mb-4 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
      <div>
        <h2 class="font-serif text-xl text-stone-800">Dental Chart Entries</h2>
        <p class="serene-subheading mt-1">Assistants and dentists can add structured chart notes per visit.</p>
      </div>
    </div>

    <div class="mb-4">
      <%= form_with model: [@patient, DentalChartEntry.new], class: "grid grid-cols-1 gap-3 md:grid-cols-5", data: { controller: "chart-annotator", chart_annotator_default_image_url_value: image_path("default_odontogram.png") } do |form| %>
        <div>
          <%= form.label :recorded_on, class: "input-label" %>
          <%= form.date_field :recorded_on, class: "input-field", value: Date.current %>
        </div>
        <div>
          <%= form.label :tooth_code, "Tooth", class: "input-label" %>
          <%= form.text_field :tooth_code, class: "input-field", placeholder: "e.g., 16, 31, A" %>
        </div>
        <div>
          <%= form.label :entry_type, class: "input-label" %>
          <%= form.select :entry_type, DentalChartEntry::ENTRY_TYPES.map { |type| [type.humanize, type] }, {}, class: "input-field" %>
        </div>
        <div class="md:col-span-2">
          <%= form.label :notes, class: "input-label" %>
          <%= form.text_field :notes, class: "input-field", placeholder: "Findings, procedure, restorations, periodontal observations..." %>
        </div>
        <div class="md:col-span-5">
          <%= form.label :chart_image, "Marked Dental Chart Image", class: "input-label" %>
          <%= form.file_field :chart_image, direct_upload: true, accept: "image/png,image/jpeg,image/webp", class: "input-field", data: { chart_annotator_target: "file", action: "change->chart-annotator#loadImage" } %>
          <p class="mt-1 text-xs text-stone-500">Optional upload. A default adult dental chart is preloaded for direct annotation.</p>
        </div>
        <div class="md:col-span-5 rounded-xl border border-stone-200 bg-stone-50 p-3">
          <div class="mb-2 flex flex-col gap-2 md:flex-row md:items-center md:justify-between">
            <p class="text-sm font-semibold text-stone-700">In-Browser Chart Annotation</p>
            <div class="flex flex-wrap items-center gap-2">
              <label class="text-xs text-stone-600">
                Color
                <input type="color" value="#c0392b" class="ml-1 h-8 w-8 cursor-pointer rounded border border-stone-300 align-middle" data-chart-annotator-target="color" data-action="input->chart-annotator#updateBrushColor">
              </label>
              <label class="text-xs text-stone-600">
                Size
                <input type="range" min="1" max="14" value="3" class="ml-1 w-24 align-middle" data-chart-annotator-target="size" data-action="input->chart-annotator#updateBrushSize">
              </label>
              <button type="button" class="btn btn-secondary px-3 py-1.5 text-xs" data-chart-annotator-target="eraser" data-action="chart-annotator#toggleEraser">Eraser</button>
              <button type="button" class="btn btn-secondary px-3 py-1.5 text-xs" data-chart-annotator-target="clear" data-action="chart-annotator#clearCanvas">Clear Annotations</button>
            </div>
          </div>
          <div class="relative overflow-auto rounded-lg border border-stone-300 bg-white p-2">
            <p class="absolute left-4 top-4 text-xs text-stone-500" data-chart-annotator-target="placeholder">Draw with mouse or touch. Upload to replace the default chart.</p>
            <div class="relative inline-block">
              <canvas data-chart-annotator-target="baseCanvas" class="block max-w-full"></canvas>
              <canvas data-chart-annotator-target="drawCanvas" class="absolute left-0 top-0 touch-none"></canvas>
            </div>
          </div>
          <%= hidden_field_tag "dental_chart_entry[annotated_image_data]", "", data: { chart_annotator_target: "hidden" } %>
        </div>
        <div class="md:col-span-5 flex justify-end">
          <%= form.submit "Add Chart Entry", class: "btn btn-primary" %>
        </div>
      <% end %>
    </div>

    <div class="table-shell">
      <table class="data-table">
        <thead>
          <tr>
            <th>Date</th>
            <th>Tooth</th>
            <th>Type</th>
            <th>Notes</th>
            <th>Chart Image</th>
            <th>Recorded By</th>
          </tr>
        </thead>
        <tbody>
          <% entries = @patient.dental_chart_entries.order(recorded_on: :desc, created_at: :desc).limit(30) %>
          <% preview_index = 0 %>
          <% if entries.any? %>
            <% entries.each do |entry| %>
              <tr>
                <td><%= l(entry.recorded_on, format: :long) %></td>
                <td><%= entry.tooth_code.presence || "N/A" %></td>
                <td><%= entry.entry_type.humanize %></td>
                <td><%= entry.notes.presence || "N/A" %></td>
                <td>
                  <% if entry.chart_image.attached? %>
                    <button
                      type="button"
                      class="rounded border border-stone-200 p-0.5 transition hover:border-[#8BA88E]"
                      data-action="image-preview#open"
                      data-image-preview-target="trigger"
                      data-preview-index="<%= preview_index %>"
                      data-full-image-url="<%= url_for(entry.chart_image) %>"
                    >
                      <%= image_tag entry.chart_image, class: "h-16 w-16 rounded object-cover" %>
                    </button>
                    <% preview_index += 1 %>
                  <% else %>
                    <span class="text-stone-500">N/A</span>
                  <% end %>
                </td>
                <td><%= entry.user.name %></td>
              </tr>
            <% end %>
          <% else %>
            <tr><td colspan="6" class="py-10 text-center text-sm text-stone-500">No dental chart entries yet.</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="app-card">
    <div class="mb-4 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
      <div>
        <h2 class="font-serif text-xl text-stone-800">Prescriptions</h2>
        <p class="serene-subheading mt-1">Draft by assistant/dentist, finalize, then digitally sign by dentist.</p>
      </div>
      <div class="flex gap-2">
        <% if can_access_feature?(:prescriptions, :view) %>
          <%= link_to "View All", patient_prescriptions_path(@patient), class: "btn btn-secondary" %>
        <% end %>
        <% if can_access_feature?(:prescriptions, :create) %>
          <%= link_to "New Prescription", new_patient_prescription_path(@patient), class: "btn btn-primary" %>
        <% end %>
      </div>
    </div>

    <div class="table-shell">
      <table class="data-table">
        <thead>
          <tr>
            <th>Issued On</th>
            <th>Status</th>
            <th>Drafted By</th>
            <th>Signed By</th>
            <th class="text-right">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% recent_prescriptions = @patient.prescriptions.recent_first.limit(10) %>
          <% if recent_prescriptions.any? %>
            <% recent_prescriptions.each do |prescription| %>
              <tr>
                <td><%= l(prescription.issued_on, format: :long) %></td>
                <td><%= prescription.status.humanize %></td>
                <td><%= prescription.drafted_by_user.name %></td>
                <td><%= prescription.signed_by_user&.name || "N/A" %></td>
                <td class="text-right">
                  <div class="flex justify-end gap-2">
                    <%= link_to "Open", patient_prescription_path(@patient, prescription), class: "btn btn-secondary px-3 py-1.5 text-xs" %>
                    <%= render "prescriptions/preview_dialog", patient: @patient, prescription: prescription %>
                  </div>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr><td colspan="5" class="py-10 text-center text-sm text-stone-500">No prescriptions yet.</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="app-card">
    <div class="mb-4 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
      <div>
        <h2 class="font-serif text-xl text-stone-800">Intra-oral Scans</h2>
        <p class="serene-subheading mt-1">Upload scan results such as STL, PLY, OBJ, ZIP, PDF, JPG, or PNG files.</p>
      </div>
    </div>

    <% if can_access_feature?(:patients, :update) %>
      <div class="mb-4">
        <%= form_with model: [@patient, IntraoralScan.new], class: "grid grid-cols-1 gap-3 md:grid-cols-5" do |form| %>
          <div>
            <%= form.label :captured_on, class: "input-label" %>
            <%= form.date_field :captured_on, class: "input-field", value: Date.current %>
          </div>
          <div>
            <%= form.label :scan_type, class: "input-label" %>
            <%= form.select :scan_type, IntraoralScan::SCAN_TYPES.map { |type| [type.humanize, type] }, {}, class: "input-field" %>
          </div>
          <div class="md:col-span-2">
            <%= form.label :scan_file, "Scan File", class: "input-label" %>
            <%= form.file_field :scan_file, direct_upload: true, accept: ".stl,.ply,.obj,.zip,.pdf,.jpg,.jpeg,.png,application/pdf,image/jpeg,image/png", class: "input-field" %>
          </div>
          <div>
            <%= form.label :notes, class: "input-label" %>
            <%= form.text_field :notes, class: "input-field", placeholder: "Lab case, arch, remarks..." %>
          </div>
          <div class="md:col-span-5 flex justify-end">
            <%= form.submit "Upload Scan", class: "btn btn-primary" %>
          </div>
        <% end %>
      </div>
    <% end %>

    <div class="table-shell">
      <table class="data-table">
        <thead>
          <tr>
            <th>Captured</th>
            <th>Type</th>
            <th>File</th>
            <th>Notes</th>
            <th>Uploaded By</th>
            <th class="text-right">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% scans = @patient.intraoral_scans.includes(:user).with_attached_scan_file.recent_first.limit(20) %>
          <% if scans.any? %>
            <% scans.each do |scan| %>
              <tr>
                <td><%= l(scan.captured_on, format: :long) %></td>
                <td><%= scan.scan_type.humanize %></td>
                <td><%= scan.scan_file.filename %></td>
                <td><%= scan.notes.presence || "N/A" %></td>
                <td><%= scan.user.name %></td>
                <td class="text-right">
                  <div class="flex justify-end gap-2">
                    <%= link_to "View", patient_intraoral_scan_path(@patient, scan), class: "btn btn-secondary px-3 py-1.5 text-xs" %>
                    <%= link_to "Download", rails_blob_path(scan.scan_file, disposition: "attachment"), class: "btn btn-secondary px-3 py-1.5 text-xs", data: { turbo: false } %>
                    <% if can_access_feature?(:patients, :destroy) %>
                      <%= button_to "Delete", patient_intraoral_scan_path(@patient, scan), method: :delete, class: "btn btn-danger px-3 py-1.5 text-xs", form: { data: { turbo_confirm: "Delete this scan?" } } %>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr><td colspan="6" class="py-10 text-center text-sm text-stone-500">No intra-oral scans uploaded yet.</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="app-card">
    <h2 class="mb-3 font-serif text-xl text-stone-800">Consent Versions</h2>
    <div class="mb-4">
      <%= form_with model: [@patient, PatientConsent.new], class: "grid grid-cols-1 gap-3 md:grid-cols-4" do |form| %>
        <div>
          <%= form.label :consent_type, class: "input-label" %>
          <%= form.select :consent_type, PatientConsent::CONSENT_TYPES.map { |type| [type.humanize, type] }, {}, class: "input-field" %>
        </div>
        <div>
          <%= form.label :document_version, class: "input-label" %>
          <%= form.text_field :document_version, class: "input-field", placeholder: "e.g., DPA-v1.2" %>
        </div>
        <div>
          <%= form.label :consented_at, class: "input-label" %>
          <%= form.datetime_field :consented_at, class: "input-field", value: Time.current.strftime("%Y-%m-%dT%H:%M") %>
        </div>
        <div class="flex items-end">
          <%= form.submit "Record Consent", class: "btn btn-primary w-full justify-center" %>
        </div>
      <% end %>
    </div>

    <div class="table-shell">
      <table class="data-table">
        <thead>
          <tr>
            <th>Type</th>
            <th>Version</th>
            <th>Consented At</th>
            <th>Recorded By</th>
          </tr>
        </thead>
        <tbody>
          <% @patient.patient_consents.order(consented_at: :desc).limit(20).each do |consent| %>
            <tr>
              <td><%= consent.consent_type.humanize %></td>
              <td><%= consent.document_version %></td>
              <td><%= l(consent.consented_at, format: :long) %></td>
              <td><%= consent.user.name %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="flex flex-wrap gap-2">
    <% if can_access_feature?(:patients, :update) %>
      <%= link_to "Edit", edit_patient_path(@patient), class: "btn btn-primary" %>
    <% end %>
    <%= link_to "Back", patients_path, class: "btn btn-secondary" %>
    <% if can_access_feature?(:patients, :destroy) %>
      <%= button_to "Destroy", @patient, method: :delete, class: "btn btn-danger" %>
    <% end %>
  </div>

  <dialog
    data-image-preview-target="dialog"
    data-action="click->image-preview#closeOnBackdrop"
    class="m-auto w-[92vw] max-w-4xl rounded-2xl border border-stone-200 p-0 backdrop:bg-black/50"
  >
    <div class="flex items-center justify-between border-b border-stone-200 px-4 py-3">
      <h3 class="font-semibold text-stone-800">Dental Chart Preview</h3>
      <div class="flex items-center gap-2">
        <span data-image-preview-target="counter" class="text-xs text-stone-500">1 / 1</span>
        <button type="button" class="btn btn-secondary px-3 py-1.5 text-xs" data-action="image-preview#previous">Prev</button>
        <button type="button" class="btn btn-secondary px-3 py-1.5 text-xs" data-action="image-preview#next">Next</button>
        <button type="button" class="btn btn-secondary px-3 py-1.5 text-xs" data-action="image-preview#close">Close</button>
      </div>
    </div>
    <div class="flex min-h-[50vh] items-center justify-center bg-stone-50 p-4">
      <img data-image-preview-target="image" alt="Dental chart preview" class="max-h-[75vh] w-full rounded bg-white object-contain">
    </div>
  </dialog>
</div>

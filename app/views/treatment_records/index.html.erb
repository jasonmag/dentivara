<% content_for :title, "Treatment Records" %>

<div class="space-y-8">
  <section class="flex items-end justify-between">
    <div>
      <h1 class="page-title">Treatment Records</h1>
      <p class="serene-subheading mt-1">Clinical procedures and outcomes across appointments.</p>
    </div>
    <%= link_to "New Treatment Record", new_treatment_record_path, class: "btn btn-primary" %>
  </section>

  <section class="table-shell">
    <table class="data-table">
      <thead>
        <tr>
          <th>Patient</th>
          <th>Provider</th>
          <th>Service</th>
          <th>Cost</th>
          <th>Performed On</th>
          <th class="text-right">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @treatment_records.each do |record| %>
          <tr>
            <td class="font-semibold text-stone-800"><%= record.patient.full_name %></td>
            <td><%= record.user.name %></td>
            <td><%= record.service_type %></td>
            <td><%= number_to_currency(record.cost || 0) %></td>
            <td><%= l(record.performed_on, format: :long) %></td>
            <td class="text-right"><%= link_to "View", treatment_record_path(record), class: "btn btn-secondary px-3 py-1.5 text-xs" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </section>
</div>

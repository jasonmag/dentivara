<%= form_with(model: document_template, data: { turbo: false, controller: "template-kind placeholder-insert" }) do |form| %>
  <%= render "shared/form_errors", model: document_template %>

  <div class="rounded-xl border border-stone-200 bg-stone-50 p-3">
    <div class="mb-2 flex items-center justify-between">
      <p class="text-xs font-semibold uppercase tracking-wide text-stone-500">Placeholders</p>
      <span data-placeholder-insert-target="feedback" class="text-xs font-semibold text-emerald-700 opacity-0 transition-opacity">Inserted</span>
    </div>
    <div class="flex flex-wrap gap-2">
      <% %w[
        patient_name
        patient_diagnosis
        patient_age
        patient_gender
        patient_weight
        doctor_name
        dentist_name
        today
        medication
        dosage
        duration
        instructions
        diagnosis
        next_visit
        clinic_name
        clinic_address
        clinic_contact_number
      ].each do |ph| %>
        <button type="button" class="btn btn-secondary px-2.5 py-1 text-xs" data-action="placeholder-insert#insert" data-token="{{<%= ph %>}}">{{<%= ph %>}}</button>
      <% end %>
    </div>
    <p class="mt-2 text-xs text-stone-500">Click inside a template field, then click a placeholder button to insert at cursor.</p>
  </div>

  <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
    <div><%= form.label :name, class: "input-label" %><%= form.text_field :name, class: "input-field" %></div>
    <div><%= form.label :kind, class: "input-label" %><%= form.select :kind, DocumentTemplate::KINDS.map { |k| [k.humanize, k] }, {}, class: "input-field", data: { template_kind_target: "kind", action: "change->template-kind#toggle" } %></div>
    <div class="contents" data-template-kind-target="signatureFields">
      <div><%= form.label :digital_signature_name, class: "input-label" %><%= form.text_field :digital_signature_name, class: "input-field" %></div>
      <div><%= form.label :digital_signature_title, class: "input-label" %><%= form.text_field :digital_signature_title, class: "input-field" %></div>
    </div>
    <div class="md:col-span-2">
      <%= form.label :logo, "Prescription Logo", class: "input-label" %>
      <%= form.file_field :logo, accept: "image/png,image/jpeg,image/webp,image/svg+xml", class: "input-field" %>
      <p class="mt-1 text-xs text-stone-500">For prescription templates, this logo appears in the top-right clinic header.</p>
      <% if document_template.logo.attached? %>
        <div class="mt-2">
          <%= image_tag document_template.logo, class: "h-14 rounded border border-stone-200 bg-white p-1 object-contain" %>
        </div>
      <% end %>
    </div>
    <div class="md:col-span-2"><%= form.label :header_text, "Clinic Header", class: "input-label" %><%= form.text_area :header_text, class: "input-field", data: { placeholder_insert_target: "field", action: "focus->placeholder-insert#activate click->placeholder-insert#activate" } %><p class="mt-1 text-xs text-stone-500">For prescriptions, this renders at the top beside the logo. Default: {{clinic_name}}, {{clinic_address}}, {{clinic_contact_number}}.</p></div>
    <div class="md:col-span-2"><%= form.label :information_header_text, "Prescription Information", class: "input-label" %><%= form.text_area :information_header_text, class: "input-field", rows: 6, data: { placeholder_insert_target: "field", action: "focus->placeholder-insert#activate click->placeholder-insert#activate" } %><p class="mt-1 text-xs text-stone-500">One field per line, for example Patient Name, Date, Age, Gender, Weight, and Diagnosis. These appear above the prescription body.</p></div>
    <div class="md:col-span-2"><%= form.label :body_template, "Prescription Description", class: "input-label" %><%= form.text_area :body_template, class: "input-field", rows: 8, data: { placeholder_insert_target: "field", action: "focus->placeholder-insert#activate click->placeholder-insert#activate" } %><p class="mt-1 text-xs text-stone-500">Use this for the medication/instructions content. The Rx mark is added automatically as a background in the preview and print layout.</p></div>
    <div class="md:col-span-2"><%= form.label :footer_text, "Clinic Footer", class: "input-label" %><%= form.text_area :footer_text, class: "input-field", data: { placeholder_insert_target: "field", action: "focus->placeholder-insert#activate click->placeholder-insert#activate" } %><p class="mt-1 text-xs text-stone-500">For prescriptions, keep this as clinic placeholders unless the clinic footer needs custom wording.</p></div>
    <div class="flex items-end gap-2"><%= form.check_box :active %><%= form.label :active, class: "input-label mb-0" %></div>
    <div class="flex items-end gap-2">
      <%= form.check_box :default_for_prescription %>
      <%= form.label :default_for_prescription, "Set as clinic default prescription template", class: "input-label mb-0" %>
    </div>
  </div>

  <div class="mt-4"><%= form.submit class: "btn btn-primary" %></div>
<% end %>

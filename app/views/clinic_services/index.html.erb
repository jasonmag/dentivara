<% content_for :title, "Clinic Services" %>
<div class="space-y-8">
  <section class="flex items-end justify-between">
    <div><h1 class="page-title">Clinic Services</h1><p class="serene-subheading mt-1">Configure procedures and pricing.</p></div>
    <%= link_to "New Service", new_clinic_service_path, class: "btn btn-primary" %>
  </section>
  <section class="table-shell">
    <table class="data-table">
      <thead><tr><th>Name</th><th>Price</th><th>Duration</th><th>Status</th><th class="text-right">Actions</th></tr></thead>
      <tbody>
        <% @clinic_services.each do |service| %>
          <tr>
            <td class="font-semibold text-stone-800"><%= service.name %></td>
            <td><%= number_to_currency(service.base_price) %></td>
            <td><%= service.duration_minutes %> min</td>
            <td><%= service.active? ? "Active" : "Inactive" %></td>
            <td class="text-right"><%= link_to "View", clinic_service_path(service), class: "btn btn-secondary px-3 py-1.5 text-xs" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </section>
</div>

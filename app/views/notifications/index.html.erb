<% content_for :title, "Notifications" %>

<div class="space-y-8">
  <section class="flex items-end justify-between">
    <div>
      <h1 class="page-title">Notifications</h1>
      <p class="serene-subheading mt-1">Track reminders and patient communication status.</p>
    </div>
    <% if can_access_feature?(:notifications, :create) %>
      <%= link_to "New Notification", new_notification_path, class: "btn btn-primary" %>
    <% end %>
  </section>

  <section class="table-shell">
    <table class="data-table">
      <thead>
        <tr>
          <th>Patient</th>
          <th>Channel</th>
          <th>Category</th>
          <th>Status</th>
          <th>Scheduled</th>
          <th class="text-right">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @notifications.each do |notification| %>
          <tr>
            <td class="font-semibold text-stone-800"><%= notification.patient.full_name %></td>
            <td><%= notification.channel %></td>
            <td><%= notification.category %></td>
            <td><%= notification.status %></td>
            <td><%= notification.scheduled_for.present? ? l(notification.scheduled_for, format: :short) : 'N/A' %></td>
            <td class="text-right"><% if can_access_feature?(:notifications, :view) %><%= link_to "View", notification_path(notification), class: "btn btn-secondary px-3 py-1.5 text-xs" %><% end %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </section>
</div>

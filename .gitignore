# Ignore bundler config
/.bundle
/.bundle_home

# Ignore log files
/log/*
!/log/.keep

# Ignore temp files
/tmp/*
!/tmp/.keep

# Ignore database
/db/*.sqlite3
/db/*.sqlite3-journal

# Ignore master key
/config/master.key

# Ignore node modules
/node_modules

# Ignore environment variables
.env
.env.*

# Ignore uploaded files
/storage/*
!/storage/.keep

# Ignore compiled assets
/public/assets

# macOS
.DS_Store

# VSCode
.vscode/

# Ruby version manager
.ruby-version

/app/assets/builds/*
!/app/assets/builds/.keep

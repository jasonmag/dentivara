<% content_for :title, "Appointment" %>

<div class="space-y-4">
  <div class="app-card">
    <%= render @appointment %>
  </div>

  <div class="flex flex-wrap gap-2">
    <%= link_to "Edit", edit_appointment_path(@appointment), class: "btn btn-primary" %>
    <%= link_to "Back", appointments_path, class: "btn btn-secondary" %>
    <%= button_to "Destroy", @appointment, method: :delete, class: "btn btn-danger" %>
  </div>
</div>

<div id="<%= dom_id user %>" class="kv-grid">
  <div class="kv-item"><p class="kv-label">Name</p><p class="kv-value"><%= user.name %></p></div>
  <div class="kv-item"><p class="kv-label">Email</p><p class="kv-value"><%= user.email %></p></div>
  <div class="kv-item"><p class="kv-label">Role</p><p class="kv-value"><%= user.role.humanize %></p></div>
  <div class="kv-item"><p class="kv-label">Updated</p><p class="kv-value"><%= l(user.updated_at, format: :long) %></p></div>
</div>

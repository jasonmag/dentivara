<% content_for :title, "Compliance Dashboard" %>
<div class="space-y-8">
  <section class="flex items-end justify-between">
    <div>
      <h1 class="page-title">Compliance Dashboard</h1>
      <p class="serene-subheading mt-1">Privacy, access, consent, and audit-chain oversight.</p>
    </div>
    <%= link_to "Export Audit CSV", audit_logs_path(format: :csv), class: "btn btn-secondary" %>
  </section>

  <section class="grid grid-cols-1 gap-6 md:grid-cols-3">
    <article class="serene-kpi">
      <p class="text-xs font-semibold uppercase tracking-wider text-stone-500">Total Patients</p>
      <p class="mt-2 font-serif text-4xl text-stone-800"><%= @total_patients %></p>
    </article>
    <article class="serene-kpi">
      <p class="text-xs font-semibold uppercase tracking-wider text-stone-500">Consented Patients</p>
      <p class="mt-2 font-serif text-4xl text-stone-800"><%= @consented_patients %></p>
    </article>
    <article class="serene-kpi">
      <p class="text-xs font-semibold uppercase tracking-wider text-stone-500">Consent Coverage</p>
      <p class="mt-2 font-serif text-4xl text-stone-800"><%= @consent_coverage %>%</p>
    </article>
  </section>

  <section class="grid grid-cols-1 gap-6 xl:grid-cols-2">
    <article class="serene-card p-6">
      <div class="mb-3 flex items-center justify-between">
        <h2 class="font-serif text-xl text-stone-800">Audit Chain Integrity</h2>
        <span class="text-xs font-semibold <%= @audit_chain[:broken_count].zero? ? 'text-emerald-700' : 'text-red-700' %>">
          <%= @audit_chain[:broken_count].zero? ? 'Healthy' : 'Issues Found' %>
        </span>
      </div>
      <p class="text-sm text-stone-600">Checked <%= @audit_chain[:total_checked] %> recent audit records.</p>
      <p class="mt-2 text-sm text-stone-600">Broken links: <strong><%= @audit_chain[:broken_count] %></strong></p>
      <% if @audit_chain[:broken_ids].any? %>
        <p class="mt-2 text-xs text-red-700">Broken IDs: <%= @audit_chain[:broken_ids].join(', ') %></p>
      <% end %>
    </article>

    <article class="serene-card p-6">
      <h2 class="mb-3 font-serif text-xl text-stone-800">Retention Controls</h2>
      <p class="text-sm text-stone-600">Run cleanup task:</p>
      <code class="mt-2 block rounded bg-stone-100 p-2 text-xs">bin/rails data_retention:cleanup</code>
      <p class="mt-3 text-xs text-stone-500">Override windows with ENV vars: ACCESS_LOG_RETENTION_DAYS and AUDIT_LOG_RETENTION_DAYS.</p>
    </article>
  </section>

  <section class="grid grid-cols-1 gap-6 xl:grid-cols-2">
    <article class="table-shell">
      <div class="border-b border-stone-100 px-4 py-3">
        <h3 class="font-serif text-lg text-stone-800">Recent Sensitive Access</h3>
      </div>
      <table class="data-table">
        <thead>
          <tr><th>Time</th><th>User</th><th>Action</th><th>Resource</th></tr>
        </thead>
        <tbody>
          <% @recent_access_logs.each do |log| %>
            <tr>
              <td><%= l(log.created_at, format: :short) %></td>
              <td><%= log.user&.email || 'System' %></td>
              <td><%= log.action %></td>
              <td><%= "#{log.resource_type}##{log.resource_id}" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </article>

    <article class="table-shell">
      <div class="border-b border-stone-100 px-4 py-3">
        <h3 class="font-serif text-lg text-stone-800">Recent Audit Events</h3>
      </div>
      <table class="data-table">
        <thead>
          <tr><th>Time</th><th>User</th><th>Action</th><th>Resource</th></tr>
        </thead>
        <tbody>
          <% @recent_audit_logs.each do |log| %>
            <tr>
              <td><%= l(log.created_at, format: :short) %></td>
              <td><%= log.user&.email || 'System' %></td>
              <td><%= log.action %></td>
              <td><%= "#{log.auditable_type}##{log.auditable_id}" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </article>
  </section>
</div>

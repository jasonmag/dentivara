<div id="<%= dom_id invoice %>" class="space-y-4">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <div>
      <p class="text-xs uppercase tracking-wide text-stone-500">Invoice Number</p>
      <p class="font-serif text-2xl text-stone-900"><%= invoice_display_number(invoice) %></p>
    </div>
    <span class="<%= invoice_status_badge_classes(invoice.status) %>"><%= invoice_payment_status_label(invoice) %></span>
  </div>

  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
    <div class="rounded-xl bg-stone-50 p-3"><p class="text-xs text-stone-500">Invoice Total</p><p class="mt-1 font-semibold text-stone-800"><%= clinic_number_to_currency(invoice.total_amount) %></p></div>
    <div class="rounded-xl bg-[#E8F1E9] p-3"><p class="text-xs text-[#4a654e]">Total Paid</p><p class="mt-1 font-semibold text-[#35513a]"><%= clinic_number_to_currency(invoice.total_paid) %></p></div>
    <div class="rounded-xl bg-amber-50 p-3"><p class="text-xs text-amber-700">Remaining Balance</p><p class="mt-1 font-semibold text-amber-800"><%= clinic_number_to_currency(invoice.balance_amount) %></p></div>
    <div class="rounded-xl bg-blue-50 p-3"><p class="text-xs text-blue-700">Credit</p><p class="mt-1 font-semibold text-blue-800"><%= clinic_number_to_currency(invoice.credit_amount) %></p></div>
  </div>

  <div>
    <div class="mb-1 flex items-center justify-between text-xs text-stone-600">
      <span>Payment progress</span>
      <span><%= format("%.1f", invoice.payment_progress_percentage) %>%</span>
    </div>
    <div class="h-2.5 w-full overflow-hidden rounded-full bg-stone-100">
      <div class="h-full rounded-full bg-[#8BA88E]" style="width: <%= invoice.payment_progress_percentage %>%"></div>
    </div>
  </div>

  <div class="kv-grid">
    <div class="kv-item"><p class="kv-label">Patient</p><p class="kv-value"><%= invoice.patient.full_name %></p></div>
    <div class="kv-item"><p class="kv-label">Treatment Record</p><p class="kv-value">#<%= invoice.treatment_record_id %></p></div>
    <div class="kv-item"><p class="kv-label">Issued On</p><p class="kv-value"><%= invoice.issued_on.present? ? l(invoice.issued_on, format: :long) : "N/A" %></p></div>
    <div class="kv-item"><p class="kv-label">Currency</p><p class="kv-value"><%= clinic_currency_code %></p></div>
    <div class="kv-item"><p class="kv-label">Dentist Approval</p><p class="kv-value"><%= invoice.approved_by_dentist_at.present? ? l(invoice.approved_by_dentist_at, format: :long) : "N/A" %></p></div>
    <div class="kv-item"><p class="kv-label">Admin Approval</p><p class="kv-value"><%= invoice.approved_by_admin_at.present? ? l(invoice.approved_by_admin_at, format: :long) : "N/A" %></p></div>
  </div>
</div>

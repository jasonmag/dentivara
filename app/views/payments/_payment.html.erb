<div id="<%= dom_id payment %>" class="kv-grid">
  <div class="kv-item"><p class="kv-label">Invoice</p><p class="kv-value">#<%= payment.invoice_id %></p></div>
  <div class="kv-item"><p class="kv-label">Patient</p><p class="kv-value"><%= payment.invoice.patient.full_name %></p></div>
  <div class="kv-item"><p class="kv-label">Amount</p><p class="kv-value"><%= clinic_number_to_currency(payment.amount) %></p></div>
  <div class="kv-item"><p class="kv-label">Paid On</p><p class="kv-value"><%= payment.paid_on.present? ? l(payment.paid_on, format: :long) : 'N/A' %></p></div>
  <div class="kv-item"><p class="kv-label">Method</p><p class="kv-value"><%= payment.method.present? ? payment.method.humanize : "N/A" %></p></div>
  <div class="kv-item"><p class="kv-label">Reference</p><p class="kv-value"><%= payment.reference_code.presence || 'N/A' %></p></div>
  <div class="kv-item"><p class="kv-label">Recorded By</p><p class="kv-value"><%= payment.recorded_by&.name || "N/A" %></p></div>
  <div class="kv-item"><p class="kv-label">Notes</p><p class="kv-value"><%= payment.notes.presence || "N/A" %></p></div>
  <div class="kv-item"><p class="kv-label">Proof</p><p class="kv-value"><%= payment.proof.attached? ? link_to("View Screenshot", rails_blob_path(payment.proof, disposition: "inline"), target: "_blank", class: "text-[#4a654e] underline") : "N/A" %></p></div>
</div>

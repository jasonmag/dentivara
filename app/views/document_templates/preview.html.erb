<% content_for :title, "Template Preview" %>
<div class="space-y-4">
  <div class="page-header"><h1 class="page-title">Preview: <%= @document_template.name %></h1><%= link_to "Back", @document_template, class: "btn btn-secondary" %></div>
  <article class="app-card space-y-4">
    <header class="whitespace-pre-line text-sm text-stone-700"><%= @rendered[:header] %></header>
    <main class="whitespace-pre-line text-sm text-stone-800"><%= @rendered[:body] %></main>
    <footer class="whitespace-pre-line text-sm text-stone-700"><%= @rendered[:footer] %></footer>
    <div class="pt-6">
      <p class="text-sm font-semibold text-stone-800"><%= @rendered[:signature_name].presence || "Digital Signature" %></p>
      <p class="text-xs text-stone-500"><%= @rendered[:signature_title] %></p>
    </div>
  </article>
</div>

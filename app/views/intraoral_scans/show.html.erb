<% content_for :title, "Intra-oral Scan" %>

<div class="space-y-6">
  <section class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
    <div>
      <h1 class="page-title">Intra-oral Scan</h1>
      <p class="serene-subheading mt-1"><%= @patient.full_name %> • <%= @intraoral_scan.scan_type.humanize %> • <%= l(@intraoral_scan.captured_on, format: :long) %></p>
    </div>
    <div class="flex flex-wrap gap-2">
      <%= link_to "Back to Patient", patient_path(@patient), class: "btn btn-secondary" %>
      <%= link_to "Download File", rails_blob_path(@intraoral_scan.scan_file, disposition: "attachment"), class: "btn btn-primary", data: { turbo: false } %>
    </div>
  </section>

  <section class="app-card">
    <div class="kv-grid">
      <div class="kv-item"><p class="kv-label">File</p><p class="kv-value"><%= @intraoral_scan.scan_file.filename %></p></div>
      <div class="kv-item"><p class="kv-label">Format</p><p class="kv-value"><%= @intraoral_scan.file_extension.upcase %></p></div>
      <div class="kv-item"><p class="kv-label">Uploaded By</p><p class="kv-value"><%= @intraoral_scan.user.name %></p></div>
      <div class="kv-item"><p class="kv-label">Uploaded At</p><p class="kv-value"><%= l(@intraoral_scan.created_at, format: :long) %></p></div>
      <div class="kv-item sm:col-span-2"><p class="kv-label">Notes</p><p class="kv-value"><%= @intraoral_scan.notes.presence || "N/A" %></p></div>
    </div>
  </section>

  <% if @intraoral_scan.viewable_3d? %>
    <section
      class="app-card"
      data-controller="intraoral-scan-viewer"
      data-intraoral-scan-viewer-url-value="<%= rails_blob_path(@intraoral_scan.scan_file, disposition: 'inline') %>"
      data-intraoral-scan-viewer-extension-value="<%= @intraoral_scan.file_extension %>"
    >
      <div class="mb-3 flex items-center justify-between">
        <h2 class="font-serif text-xl text-stone-800">3D Preview</h2>
        <p class="text-xs text-stone-500" data-intraoral-scan-viewer-target="status">Preparing scan preview...</p>
      </div>
      <div data-intraoral-scan-viewer-target="viewport" class="h-[520px] min-h-[420px] w-full overflow-hidden rounded-lg border border-stone-200 bg-stone-50"></div>
    </section>
  <% elsif @intraoral_scan.scan_file.content_type.start_with?("image/") %>
    <section class="app-card">
      <h2 class="mb-3 font-serif text-xl text-stone-800">Image Preview</h2>
      <%= image_tag @intraoral_scan.scan_file, class: "max-h-[70vh] w-full rounded-lg border border-stone-200 bg-white object-contain" %>
    </section>
  <% elsif @intraoral_scan.scan_file.content_type == "application/pdf" %>
    <section class="app-card">
      <h2 class="mb-3 font-serif text-xl text-stone-800">PDF Preview</h2>
      <iframe src="<%= rails_blob_path(@intraoral_scan.scan_file, disposition: 'inline') %>" class="h-[70vh] w-full rounded-lg border border-stone-200"></iframe>
    </section>
  <% else %>
    <section class="app-card">
      <h2 class="mb-2 font-serif text-xl text-stone-800">Preview Not Available</h2>
      <p class="text-sm text-stone-600">This file can be downloaded and opened in the dental scanner or lab software that produced it.</p>
    </section>
  <% end %>
</div>

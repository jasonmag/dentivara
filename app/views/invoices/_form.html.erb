<%= form_with(model: invoice) do |form| %>
  <% if invoice.errors.any? %>
    <div class="mb-4 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800">
      <p class="font-semibold"><%= pluralize(invoice.errors.count, "error") %> prevented this invoice from being saved:</p>
      <ul class="mt-2 list-disc pl-5">
        <% invoice.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
    <div>
      <%= form.label :patient_id, class: "input-label" %>
      <%= form.collection_select :patient_id, Patient.order(:first_name), :id, :full_name, { prompt: "Select patient" }, class: "input-field" %>
    </div>
    <div>
      <%= form.label :treatment_record_id, class: "input-label" %>
      <%= form.collection_select :treatment_record_id, TreatmentRecord.order(performed_on: :desc), :id, :id, { prompt: "Select treatment record" }, class: "input-field" %>
    </div>
    <div>
      <%= form.label :status, class: "input-label" %>
      <%= form.select :status, Invoice::STATUSES.map { |value| [value.humanize, value] }, {}, class: "input-field" %>
    </div>
    <div>
      <%= form.label :issued_on, class: "input-label" %>
      <%= form.date_field :issued_on, class: "input-field" %>
    </div>
    <div>
      <%= form.label :total_amount, class: "input-label" %>
      <%= form.number_field :total_amount, step: 0.01, class: "input-field" %>
    </div>
    <div>
      <%= form.label :balance_amount, class: "input-label" %>
      <%= form.number_field :balance_amount, step: 0.01, class: "input-field" %>
    </div>
    <div>
      <%= form.label :approved_by_dentist_at, class: "input-label" %>
      <%= form.datetime_field :approved_by_dentist_at, class: "input-field" %>
    </div>
    <div>
      <%= form.label :approved_by_admin_at, class: "input-label" %>
      <%= form.datetime_field :approved_by_admin_at, class: "input-field" %>
    </div>
  </div>

  <div class="mt-4">
    <%= form.submit class: "btn btn-primary" %>
  </div>
<% end %>
